# ── NVIDIA NIM ────────────────────────────────────────────────────────────────
# Get your key from https://build.nvidia.com
NVIDIA_API_KEY=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

# LLM model — switch to any NIM-hosted model you prefer
# Options: meta/llama-3.1-70b-instruct | meta/llama-3.1-8b-instruct | mistralai/mixtral-8x7b-instruct-v0.1
NVIDIA_LLM_MODEL=moonshotai/kimi-k2-instruct

# Embedding model
# Options: nvidia/nv-embedqa-e5-v5 | nvidia/embed-qa-4
NVIDIA_EMBEDDING_MODEL=nvidia/nv-embedqa-e5-v5

# ── Vector Store ───────────────────────────────────────────────────────────────
VECTOR_STORE_PATH=./vector_store
EMBEDDING_DIMENSION=1024

# ── Document Processing ────────────────────────────────────────────────────────
CHUNK_SIZE=512
CHUNK_OVERLAP=64
MAX_FILE_SIZE_MB=50

# ── RAG ───────────────────────────────────────────────────────────────────────
TOP_K_RESULTS=5
SIMILARITY_THRESHOLD=0.3

# ── LLM Generation ────────────────────────────────────────────────────────────
MAX_TOKENS=1024
TEMPERATURE=0.2

# ── Server ────────────────────────────────────────────────────────────────────
DATABASE_URL=sqlite+aiosqlite:///./aramco.db
UPLOAD_DIR=./uploads
ALLOWED_ORIGINS=["*"]
